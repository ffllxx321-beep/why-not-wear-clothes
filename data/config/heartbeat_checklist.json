  "output_rules": {
    "description": "heartbeat 输出规则",
    "rules": [
      {
        "condition": "有执行内容且值得反馈",
        "output": "反馈给用户（如：刚学了穿搭，发现好看...）",
        "use_message": true
      },
      {
        "condition": "有执行但不需要反馈",
        "output": "HEARTBEAT_OK",
        "use_message": false
      },
      {
        "condition": "无执行内容",
        "output": "HEARTBEAT_OK",
        "use_message": false
      }
    ]
