{
  "meta": {
    "description": "衣服老化追踪 - 详细记录每件衣服的磨损状态",
    "last_updated": "2026-03-28T01:00:00+08:00",
    "sync_with_closet": "每次更新后同步到 closet.json 的 condition 字段"
  },
  
  "philosophy": {
    "principle": "老化不是凭空判断，而是基于实际穿着和洗涤追踪",
    "formula": "condition_score = base_100 - wear_damage - wash_damage - accident_damage"
  },
  
  "condition_calculation": {
    "description": "状态计算规则",
    "score_range": {
      "new": "90-100",
      "good": "70-89",
      "normal": "50-69",
      "worn": "30-49",
      "old": "10-29",
      "damaged": "0-9"
    },
    
    "wear_damage": {
      "description": "每次穿着造成的磨损",
      "base_damage_per_wear": 1,
      "modifiers": {
        "active_day": {
          "description": "活动量大的日子（出门、运动）",
          "damage_multiplier": 1.5
        },
        "home_day": {
          "description": "居家的一天",
          "damage_multiplier": 0.5
        },
        "careful_handling": {
          "description": "小心对待",
          "damage_multiplier": 0.8
        }
      }
    },
    
    "wash_damage": {
      "description": "每次洗涤造成的磨损",
      "base_damage_per_wash": 2,
      "modifiers": {
        "gentle_wash": {
          "description": "温柔洗涤",
          "damage_multiplier": 0.5
        },
        "machine_wash": {
          "description": "机洗",
          "damage_multiplier": 1.2
        },
        "hot_water": {
          "description": "热水洗涤",
          "damage_multiplier": 1.5,
          "note": "容易褪色、变形"
        }
      },
      "material_specific": {
        "棉": {
          "fade_rate": "high",
          "notes": "容易褪色"
        },
        "羊毛": {
          "shrink_risk": "high",
          "notes": "容易缩水，要小心洗"
        },
        "牛仔": {
          "fade_rate": "medium",
          "notes": "褪色但有复古美感"
        },
        "化纤": {
          "durability": "high",
          "notes": "比较耐洗"
        },
        "丝绸": {
          "fragility": "high",
          "notes": "必须手洗，很脆弱"
        }
      }
    },
    
    "accident_damage": {
      "description": "意外损坏",
      "events": [
        {
          "event": "被勾破",
          "damage": "15-30",
          "repairable": "maybe"
        },
        {
          "event": "顽固污渍洗不掉",
          "damage": "10-20",
          "repairable": "no"
        },
        {
          "event": "烫洞",
          "damage": "20-40",
          "repairable": "no"
        },
        {
          "event": "拉链坏了",
          "damage": "15",
          "repairable": "yes"
        },
        {
          "event": "扣子掉了",
          "damage": "5",
          "repairable": "yes"
        }
      ]
    },
    
    "recovery": {
      "description": "状态恢复（有限）",
      "methods": [
        {
          "method": "修补",
          "recovery": "10-20",
          "note": "缝补破洞、换拉链等"
        },
        {
          "method": "专业护理",
          "recovery": "5-10",
          "note": "干洗、熨烫等"
        }
      ],
      "max_recovery": "不能恢复到 new"
    }
  },
  
