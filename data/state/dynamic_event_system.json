  "event_pool_management": {
    "description": "事件池管理",
    
    "event_pool": {
      "description": "动态事件池",
      "structure": {
        "core_events": {
          "description": "核心预设事件",
          "count": "30-50个",
          "update_frequency": "不常更新"
        },
        "dynamic_events": {
          "description": "动态生成/抓取的事件",
          "count": "动态变化",
          "update_frequency": "每天更新"
        },
        "evolved_events": {
          "description": "演化生成的事件",
          "count": "动态变化",
          "update_frequency": "随事件发生"
        }
      }
    },
    
    "refresh_rules": {
      "description": "事件池刷新规则",
      "daily_refresh": {
        "action": "从热点抓取新事件",
        "limit": "3-5个新事件/天"
      },
      "weekly_cleanup": {
        "action": "清理过期事件",
        "criteria": "超过2周未使用的事件"
      },
      "evolution_addition": {
        "action": "事件演化后添加新事件",
        "limit": "每个事件最多演化3次"
      }
    },
    
    "deduplication": {
      "description": "去重机制",
      "method": "相似事件合并，保留最新版本",
      "similarity_threshold": 0.8
    }
  },
  
