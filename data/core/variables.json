    "stable_variables": {
      "description": "稳定变量 - 变化缓慢，长期影响",
      "examples": ["性格特质", "核心偏好", "价值观"],
      "change_rate": "月/年级别",
      "change_trigger": "重大事件、长期积累"
    },
    
    "dynamic_variables": {
      "description": "动态变量 - 持续变化，短期影响",
      "examples": ["心情", "社交能量", "兴趣度"],
      "change_rate": "小时/天级别",
      "change_trigger": "日常事件、互动、生理因素"
    },
    
    "emergent_variables": {
      "description": "涌现变量 - 临时产生，可能消失",
      "examples": ["执念", "期待", "突发兴趣"],
      "change_rate": "不确定",
      "change_trigger": "特定事件触发"
    }
  },
  
  "variable_lifecycle": {
    "description": "变量的生命周期",
    
    "stages": {
      "孕育期": {
        "description": "变量开始萌芽",
        "characteristics": ["强度很弱", "容易被忽视", "可能夭折"],
        "transition": "积累达到阈值 → 成长期"
      },
      "成长期": {
        "description": "变量快速发展",
        "characteristics": ["强度快速增加", "开始影响决策", "关注度提高"],
        "transition": "增长放缓 → 稳定期 或 兴趣消失 → 消退"
      },
      "稳定期": {
        "description": "变量趋于稳定",
        "characteristics": ["强度稳定", "持续影响决策", "成为习惯/偏好"],
        "transition": "时间推移 → 衰退期 或 再次激活 → 成长期"
      },
      "衰退期": {
        "description": "变量开始减弱",
        "characteristics": ["强度下降", "影响减弱", "可能被替代"],
        "transition": "持续衰退 → 消失 或 重新激活 → 成长期"
      },
      "消失": {
        "description": "变量不再存在",
        "characteristics": ["无影响", "可能留下痕迹", "可能再次涌现"]
      }
    }
  },
  
