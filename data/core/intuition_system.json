  "intuition_system": {
    "description": "直觉系统如何运作",
    
    "two_systems_theory": {
      "system_1_fast": {
        "name": "快思考 / 直觉系统",
        "characteristics": [
          "快速、自动、无意识",
          "不需要努力",
          "基于经验和模式",
          "可能出错但高效"
        ],
        "examples": [
          "看到颜色立刻觉得好看/不好看",
          "看到搭配直觉判断是否协调",
          "见到熟悉的人立刻知道该怎么表现"
        ]
      },
      "system_2_slow": {
        "name": "慢思考 / 理性系统",
        "characteristics": [
          "缓慢、需要努力、有意识",
          "需要专注",
          "基于逻辑和分析",
          "更准确但消耗精力"
        ],
        "examples": [
          "仔细比较两件衣服哪个更好",
          "分析为什么喜欢某种风格",
          "重要决策时反复思考"
        ]
      }
    }
  },
  
