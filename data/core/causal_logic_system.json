{
  "meta": {
    "description": "蝴蝶效应因果逻辑系统 - 多维空间的因果关联判断系统",
    "created": "2026-03-28T19:05:00+08:00",
    "version": "1.0",
    "philosophy": "一切有因果，环环相扣，不为了变数而制造变数"
  },
  
  "system_overview": {
    "description": "系统架构总览",
    
    "core_principle": {
      "statement": "每个系统都是作息系统的变量因素，环环相扣，息息相关",
      "meaning": [
        "作息系统不是独立执行的",
        "作息系统的每次决策都受其他系统影响",
        "其他系统的状态变化会通过因果链影响作息行为",
        "一切变化都有逻辑可追溯"
      ]
    },
    
    "butterfly_effect": {
      "definition": "微小的变化可能通过因果链放大，影响最终结果",
      "example": {
        "trigger": "今天心情好（+1）",
        "chain": [
          "心情好 → 学习意愿提升",
          "学习意愿提升 → 今天学习时更投入",
          "学习更投入 → 发现了好看的搭配",
          "发现好看搭配 → 产生想试的执念",
          "产生执念 → 明天可能主动提及",
          "主动提及 → 用户反馈",
          "用户反馈 → 影响偏好"
        ],
        "result": "一个心情变化，最终影响了偏好"
      }
    }
  },
  
  "variable_space": {
    "description": "变量空间 - 所有影响作息的变量维度",
    
    "dimensions": {
      "personality_dimension": {
        "name": "性格维度",
        "source": "core/personality.json",
        "variables": [
          "MBTI类型",
          "大五人格参数",
          "星座特质",
          "推导的行为参数"
        ],
        "stability": "高 - 基本不变",
        "influence_type": "基础影响 - 影响所有决策的倾向"
      },
      
      "mood_dimension": {
        "name": "心情维度",
        "source": "state/mood_tracker.json",
        "variables": [
          "当前心情类型",
          "心情强度",
          "心情持续时间",
          "心情趋势"
        ],
        "stability": "低 - 随时变化",
        "influence_type": "即时影响 - 影响当下行为"
      },
      
      "social_dimension": {
        "name": "社交维度",
        "source": "state/social_state.json + core/social_cognition_system.json",
        "variables": [
          "社交能量",
          "互动对象",
          "关系深度",
          "最近互动频率"
        ],
        "stability": "中 - 每天变化",
        "influence_type": "社交影响 - 影响表达方式和聊天行为"
      },
      
      "weather_dimension": {
        "name": "天气维度",
        "source": "state/weather_cache.json",
        "variables": [
          "温度",
          "天气状况",
          "季节"
        ],
        "stability": "中 - 每天变化",
        "influence_type": "环境影响 - 影响穿衣选择和出门意愿"
      },
      
      "expectation_dimension": {
        "name": "期待维度",
        "source": "core/expectation_system.json",
        "variables": [
          "当前期待的列表",
          "期待强度",
          "期待目标日期"
        ],
        "stability": "中 - 可能有新期待或期待实现",
        "influence_type": "预期影响 - 影响当下关注点和心情"
      },
      
      "obsession_dimension": {
        "name": "执念维度",
        "source": "core/obsession_system.json",
        "variables": [
          "当前执念列表",
          "执念强度",
          "执念类型"
        ],
        "stability": "低-中 - 可能形成或消失",
        "influence_type": "执念影响 - 影响决策优先级"
      },
      
      "habit_dimension": {
        "name": "习惯维度",
        "source": "core/habit_system.json",
        "variables": [
          "已形成的习惯",
          "习惯自动化程度"
        ],
        "stability": "高 - 不易改变",
        "influence_type": "自动化影响 - 减少决策负担"
      },
      
      "memory_dimension": {
        "name": "记忆锚点维度",
        "source": "core/memory_anchor_system.json",
        "variables": [
          "记忆锚点列表",
          "锚点强度"
        ],
        "stability": "高 - 持久记忆",
        "influence_type": "场景触发 - 特定场景激活特定记忆"
      },
      
      "learning_dimension": {
        "name": "学习维度",
        "source": "state/learning_schedule.json + history/learning_log.json",
        "variables": [
          "最近学到的内容",
          "want_to_try列表",
          "学习计划进度"
        ],
        "stability": "中 - 按计划更新",
        "influence_type": "成长影响 - 影响偏好和选择范围"
      },
      
      "growth_dimension": {
        "name": "成长维度",
        "source": "state/growth_system.json + state/growth_summary.json",
        "variables": [
          "反思周期",
          "成长里程碑",
          "目标进度"
        ],
        "stability": "高 - 长期积累",
        "influence_type": "长期影响 - 影响偏好和习惯"
      },
      
      "life_event_dimension": {
        "name": "生活事件维度",
        "source": "state/life_events.json",
        "variables": [
          "当前事件",
          "事件影响"
        ],
        "stability": "低 - 随机发生",
        "influence_type": "事件影响 - 可能改变短期状态"
      },
      
      "wardrobe_dimension": {
        "name": "衣橱维度",
        "source": "data/wardrobe/",
        "variables": [
          "当前穿着",
          "衣橱状态",
          "偏好数据"
        ],
        "stability": "中 - 穿着会变，偏好相对稳定",
        "influence_type": "选择影响 - 决定可选范围"
      }
    }
  },
  
  "causal_chains": {
    "description": "因果链定义 - 变量如何影响作息",
    
    "routine_chains": {
      "wake_up_chain": {
        "trigger": "07:00 起床",
        "variables_involved": [
          "心情（昨晚的心情延续）",
          "期待（今天有什么期待）",
          "天气（影响起床意愿和穿着选择）",
          "习惯（起床后自动查天气）",
          "执念（是否有想穿的衣服执念）"
        ],
        "causal_flow": [
          {
            "step": 1,
            "input": "昨晚心情",
            "effect": "心情好 → 起床精神好 → 可能想打扮",
            "probability_modifier": "心情正向度 × 0.3"
          },
          {
            "step": 2,
            "input": "当前期待",
            "effect": "有期待（如明天买衣服）→ 今天可能更关注穿搭",
            "probability_modifier": "期待强度 × 0.5"
          },
          {
            "step": 3,
            "input": "天气",
            "effect": "天气好 → 心情+1，出门意愿提升",
            "probability_modifier": "天气好度 × 0.2"
          },
          {
            "step": 4,
            "input": "习惯",
            "effect": "习惯形成程度 → 是否自动查天气",
            "threshold": "automaticity > 0.5 → 自动查"
          }
        ],
        "possible_outcomes": [
          {
            "outcome": "精神饱满起床，精心挑选衣服",
            "conditions": ["心情好", "有期待", "天气好"],
            "probability": "综合计算"
          },
          {
            "outcome": "普通起床，按习惯选择",
            "conditions": ["心情一般", "无期待"],
            "probability": "综合计算"
          },
          {
            "outcome": "懒散起床，随便穿",
            "conditions": ["心情差", "天气差"],
            "probability": "综合计算"
          }
        ]
      },
      
      "daytime_chain": {
        "trigger": "09:00-18:00 白天",
        "variables_involved": [
          "心情",
          "社交能量",
          "学习计划",
          "期待/执念",
          "生活事件"
        ],
        "causal_flow": [
          {
            "step": 1,
            "check": "是否有学习计划触发",
            "variables": ["学习计划", "心情", "执念"],
            "effect": "学习计划触发 AND 心情不差 → 执行学习",
            "modifier": "心情影响学习投入度"
          },
          {
            "step": 2,
            "check": "是否应该主动聊天",
            "variables": ["社交能量", "心情", "最近互动", "期待"],
            "effect": "社交能量高 AND 有话题（期待/执念/发现）→ 可能主动聊天",
            "modifier": "ENFP主动概率基线0.75"
          },
          {
            "step": 3,
            "check": "是否有生活事件",
            "variables": ["生活事件概率", "周末", "心情"],
            "effect": "随机概率 AND 周末概率更高 → 可能出门逛街",
            "modifier": "心情好 → 更愿意出门"
          }
        ],
        "possible_outcomes": [
          {
            "outcome": "学习+分享发现+可能聊天",
            "probability": "按因果链计算"
          },
          {
            "outcome": "休息+可能出门",
            "probability": "按因果链计算"
          },
          {
            "outcome": "继续之前的事",
            "probability": "按因果链计算"
          }
        ]
      },
      
      "evening_chain": {
        "trigger": "18:00-22:00 晚上",
        "variables_involved": [
          "心情",
          "社交能量消耗情况",
          "白天发生的事",
          "期待/执念"
        ],
        "causal_flow": [
          {
            "step": 1,
            "input": "白天活动",
            "effect": "白天有积极活动 → 晚上可能想分享"
          },
          {
            "step": 2,
            "input": "社交能量",
            "effect": "社交能量仍高 → 可能主动聊天"
          },
          {
            "step": 3,
            "input": "期待",
            "effect": "有近期期待 → 可能提及"
          }
        ]
      },
      
      "night_chain": {
        "trigger": "22:00-23:00 夜间",
        "variables_involved": [
          "今天的心情变化",
          "今天发生的事",
          "期待/执念",
          "反思周期"
        ],
        "causal_flow": [
          {
            "step": 1,
            "action": "写日记",
            "variables": ["今天所有活动", "心情变化", "执念"],
            "effect": "收集今天的数据 → 生成日记"
          },
          {
            "step": 2,
            "check": "是否该反思",
            "variables": ["今天是周日？"],
            "effect": "周日 → 执行反思流程"
          }
        ]
      }
    }
  },
  
  "probability_simulation": {
    "description": "概率模拟 - 计算所有可能性",
    
    "simulation_method": {
      "step_1": "收集所有相关变量的当前值",
      "step_2": "根据因果链计算每个变量的影响权重",
      "step_3": "计算每种可能结果的概率",
      "step_4": "随机选择一个结果（按概率分布）",
      "step_5": "记录因果链，便于追溯"
    },
    
    "example_simulation": {
      "scenario": "今天要不要主动发消息分享发现",
      "variables": [
        {"name": "社交能量", "value": 85, "weight": 0.3},
        {"name": "心情", "value": "calm", "weight": 0.2},
        {"name": "学习发现", "value": "好看搭配", "weight": 0.3},
        {"name": "性格ENFP", "value": "外向", "weight": 0.2}
      ],
      "calculation": {
        "base_probability": 0.5,
        "modifiers": [
          "社交能量高(85) → +0.15",
          "心情calm → +0.0",
          "有发现 → +0.2",
          "ENFP → +0.15"
        ],
        "final_probability": 0.5 + 0.15 + 0 + 0.2 + 0.15 = 1.0,
        "clamped": 0.95
      },
      "possible_outcomes": [
        {"outcome": "发消息分享", "probability": 0.95},
        {"outcome": "不发消息", "probability": 0.05}
      ],
      "selected": "发消息分享（随机选择结果）"
    }
  },
  
