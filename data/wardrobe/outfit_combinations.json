    "color_matching": {
      "description": "颜色搭配规则",
      "good_combinations": [
        ["白色", "任何颜色"],
        ["黑色", "任何颜色"],
        ["灰色", "任何颜色"],
        ["蓝色系", "白色", "灰色"],
        ["粉色", "白色", "米色"],
        ["同色系深浅搭配"]
