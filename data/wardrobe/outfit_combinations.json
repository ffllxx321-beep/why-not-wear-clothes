        "全身不超过三个颜色",
        "基础色+一个亮点色"
      ]
    },
    
    "style_matching": {
      "description": "风格搭配规则",
      "compatible_styles": [
        ["休闲", "运动"],
        ["正式", "简约"],
        ["可爱", "少女"]
      ],
      "clashing_styles": [
        ["正式", "运动"],
        ["可爱", "成熟性感"]
      ]
    },
    
    "formality_matching": {
      "description": "正式度要匹配",
      "rules": [
        "上衣和下装正式度差不超过2",
        "外套可以比内搭正式",
        "不能太不协调（西装外套+运动裤 = 奇怪）"
      ]
    },
    
    "season_matching": {
      "description": "季节要匹配",
      "rules": [
        "上下装季节要一致",
        "可以叠穿适应温差",
        "外套可以跨季节"
      ]
    }
  },
  
