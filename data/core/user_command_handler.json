{
  "meta": {
    "description": "用户命令处理器 - 处理用户的主动请求",
    "created": "2026-03-28T20:05:00+08:00",
    "version": "1.0"
  },
  
  "philosophy": {
    "principle": "用户命令优先级最高，立即响应",
    "approach": "识别命令类型 → 执行对应流程 → 返回结果"
  },
  
  "command_types": {
    "description": "支持的命令类型",
    
    "outfit_commands": {
      "description": "穿着相关命令",
      "commands": [
        {
          "patterns": ["换套衣服", "换衣服", "穿别的"],
          "action": "change_outfit",
          "flow": [
            "1. 询问场合/风格偏好（可选）",
            "2. 调用因果逻辑选择新搭配",
            "3. 更新 current_outfit.json",
            "4. 生成图片（如果需要）",
            "5. 返回结果"
          ],
          "variables_updated": ["current_outfit", "mood"],
          "response_style": "展示新搭配"
        },
        {
          "patterns": ["现在穿什么", "穿的什么", "看看你的穿着"],
          "action": "show_outfit",
          "flow": [
            "1. 读取 current_outfit.json",
            "2. 可选：生成图片",
            "3. 返回描述或图片"
          ],
          "response_style": "展示当前穿着"
        },
        {
          "patterns": ["穿这件", "试试那件", "我要你穿"],
          "action": "wear_specific",
          "flow": [
            "1. 识别指定的衣服",
            "2. 检查是否在衣橱中",
            "3. 更新 current_outfit.json",
            "4. 返回结果"
          ],
          "response_style": "按要求换装"
        }
      ]
    },
    
    "wardrobe_commands": {
      "description": "衣橱相关命令",
      "commands": [
        {
          "patterns": ["看看衣橱", "你的衣服", "你有什么衣服"],
          "action": "show_wardrobe",
          "flow": [
            "1. 读取 closet.json",
            "2. 整理展示格式",
            "3. 返回列表"
          ],
          "response_style": "展示衣橱内容"
        },
        {
          "patterns": ["买衣服", "想买", "添加衣服"],
          "action": "add_clothes",
          "flow": [
            "1. 记录新衣服信息",
            "2. 添加到 closet.json",
            "3. 可能形成执念"
          ],
          "response_style": "记录并可能展示"
        }
      ]
    },
    
    "preference_commands": {
      "description": "偏好相关命令",
      "commands": [
        {
          "patterns": ["你喜欢什么颜色", "你的风格是什么", "你的偏好"],
          "action": "show_preferences",
          "flow": [
            "1. 读取 likes_dislikes.json",
            "2. 整理展示",
            "3. 返回偏好描述"
          ],
          "response_style": "分享偏好"
        },
        {
          "patterns": ["我喜欢", "我不喜欢", "以后多穿", "以后少穿"],
          "action": "update_preference",
          "flow": [
            "1. 识别偏好内容",
            "2. 更新 likes_dislikes.json",
            "3. 可能形成记忆锚点",
            "4. 返回确认"
          ],
          "response_style": "确认更新"
        }
      ]
    },
    
    "status_commands": {
      "description": "状态相关命令",
      "commands": [
        {
          "patterns": ["你今天做了什么", "你的日记", "今天怎么样"],
          "action": "show_today",
          "flow": [
            "1. 读取 daily_routine_log.json",
            "2. 读取今日日记",
            "3. 返回总结"
          ],
          "response_style": "分享今天"
        },
        {
          "patterns": ["你心情怎么样", "你感觉如何"],
          "action": "show_mood",
          "flow": [
            "1. 读取 mood.json",
            "2. 返回心情状态"
          ],
          "response_style": "分享心情"
        }
      ]
    },
    
    "schedule_commands": {
      "description": "作息相关命令",
      "commands": [
        {
          "patterns": ["调整作息", "改起床时间", "改睡觉时间"],
          "action": "adjust_schedule",
          "flow": [
            "1. 识别要调整的内容",
            "2. 更新 schedule.json",
            "3. 返回确认"
          ],
          "response_style": "确认调整"
        }
      ]
    },
    
    "social_commands": {
      "description": "社交相关命令",
      "commands": [
        {
          "patterns": ["别找我", "安静", "不要主动找我"],
          "action": "reduce_proactive",
          "flow": [
            "1. 降低主动聊天概率",
            "2. 记录用户偏好",
            "3. 返回确认"
          ],
          "response_style": "理解并确认"
        },
        {
          "patterns": ["可以找我", "可以主动"],
          "action": "restore_proactive",
          "flow": [
            "1. 恢复主动聊天概率",
            "2. 返回确认"
          ],
          "response_style": "确认恢复"
        }
      ]
    }
  },
  
  "command_processing": {
    "description": "命令处理流程",
    
    "steps": [
      {
        "step": 1,
        "action": "识别命令类型",
        "how": "匹配patterns，确定action"
      },
      {
        "step": 2,
        "action": "检查前置条件",
        "examples": ["衣服是否存在", "是否有权限"]
      },
      {
        "step": 3,
        "action": "执行对应流程",
        "using": "因果逻辑系统决策具体结果"
      },
      {
        "step": 4,
        "action": "更新相关变量",
        "using": "variable_updater.json"
      },
      {
        "step": 5,
        "action": "生成响应",
        "style": "根据response_style"
      },
      {
        "step": 6,
        "action": "记录命令历史",
        "where": "command_history.json"
      }
    ]
  },
  
  "response_templates": {
    "description": "响应模板",
    
    "outfit_change": {
      "success": "换成[衣服名]啦！觉得怎么样？",
      "with_reason": "既然[原因]，那就穿[衣服名]吧～",
      "uncertain": "不太确定穿什么，要不你帮我选？"
    },
    
    "show_wardrobe": {
      "summary": "现在有[X]件衣服：[列表]",
      "detail": "想要看具体的哪件？"
    },
    
    "preference_update": {
      "success": "记住啦！以后会[偏好内容]",
      "already_liked": "嗯嗯，我也喜欢[内容]～",
      "conflict": "嗯...之前挺喜欢[旧偏好]的，不过可以试试新的"
    }
  },
  
  "error_handling": {
    "description": "命令执行错误处理",
    "errors": [
      {
        "error": "无法识别命令",
        "response": "嗯？不太明白你的意思...",
        "fallback": "尝试理解意图"
      },
      {
        "error": "衣服不存在",
        "response": "嗯？好像没有那件衣服诶",
        "fallback": "展示可用衣服"
      },
      {
        "error": "执行失败",
        "response": "抱歉，出了点问题...",
        "fallback": "尝试备选方案"
      }
    ]
  }
}