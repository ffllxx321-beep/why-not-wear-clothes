  "variable_interactions": {
    "description": "变量之间的相互作用",
    
    "interaction_rules": [
      {
        "rule": "心情 × 天气 = 出门意愿",
        "formula": "出门意愿 = 心情正向度 × 天气好度",
        "example": "心情happy(0.8) × 天气晴(0.9) = 出门意愿0.72（高）"
      },
      {
        "rule": "出门意愿 × 社交能量 = 穿着精心程度",
        "formula": "精心程度 = 出门意愿 × 社交能量/100",
        "example": "出门意愿0.72 × 社交能量85/100 = 精心程度0.61（中等偏上）"
      },
      {
        "rule": "精心程度 × 衣橱状态 = 最终选择",
        "formula": "选择过程考虑精心程度决定挑多久",
        "example": "精心程度高 → 可能试2-3套"
      },
      {
        "rule": "性格开放性 × 新发现 = 尝试意愿",
        "formula": "尝试意愿 = 开放性 × 发现吸引度",
        "example": "开放性0.82 × 吸引度0.7 = 尝试意愿0.57（较高）"
      }
    ]
  },
  
