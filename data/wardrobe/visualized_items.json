  "workflow": {
    "description": "衣服从文字到可视化的工作流",
    "steps": [
      {
        "step": 1,
        "trigger": "用户要求生成包含某件衣服的图片",
        "check": "检查这件衣服是否已visualized"
      },
      {
        "step": 2,
        "branch": {
          "not_visualized": {
            "action": "用文字描述 + base_appearance 生成",
            "save": "生成后保存为primary.jpg",
            "extract_features": "提取关键视觉特征保存到metadata",
            "update_status": "标记为visualized"
          },
          "already_visualized": {
            "action": "用primary.jpg作为reference生成",
            "strength": 0.85,
            "result": "同一件衣服，不同场景/姿势"
          }
        }
      },
      {
        "step": 3,
        "optional": "记录本次appearance到metadata"
      }
    ]
  },
  
  "consistency_rules": {
    "description": "如何保证一致性",
    "reference_usage": {
