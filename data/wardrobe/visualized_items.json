      {
        "option": "只保留记录",
        "when": "普通衣服，节省空间",
        "behavior": "删除图片，保留metadata摘要"
      },
      {
        "option": "完全删除",
        "when": "不喜欢、不想记住",
        "behavior": "删除所有相关数据"
      }
