  "pitfalls": {
    "pajama_look_causes": [
      "上下材质完全一致（如全缎面）",
      "版型过于松垮",
      "颜色过于浑浊"
    ],
    "color_clashes": [
      "荧光色+黑丝",
      "亮片/反光面料+黑丝",
      "全身过黑（不露肤）"
    ],
    "solutions": [
      "换成棉质上衣或加入针织、牛仔元素",
      "塞衣角或系腰带明确腰线",
      "保持色彩明度或深沉高级",
      "低饱和度颜色配黑丝",
      "一定要露肤或用亮色配饰提亮"
    ]
  }
