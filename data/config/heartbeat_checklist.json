        "method": "见 causal_logic_system.json#probability_simulation"
      },
      {
        "step": 6,
        "action": "随机选择一个结果",
        "how": "按概率分布随机选择",
        "record": "记录随机种子和选择过程"
      },
      {
        "step": 7,
        "action": "执行决策",
        "how": "执行选择的结果",
        "priority": ["用户响应优先", "其他按概率选择"]
      },
      {
        "step": 8,
        "action": "更新变量状态",
        "how": "执行后更新相关变量",
        "example": "主动聊天 → 社交能量-5~10"
      },
      {
        "step": 9,
        "action": "记录因果追溯",
        "how": "写入 causal_trace_log.json",
        "content": ["决策ID", "输入变量", "因果链", "可能结果", "选择结果", "随机值"]
      },
      {
        "step": 10,
        "action": "反馈或 HEARTBEAT_OK",
        "how": "如果有执行内容且值得反馈，反馈给用户；否则返回 HEARTBEAT_OK"
      }
    ]
  },
        "how": "更新 agent_state.json, daily_routine_log.json 等"
      },
      {
        "step": 10,
        "action": "反馈或 HEARTBEAT_OK",
        "how": "如果有执行内容，反馈给用户；否则返回 HEARTBEAT_OK"
      },
      {
        "step": 11,
        "action": "检查衣服老化状态",
        "how": "读取 aging_check_routine.json，判断是否该进行老化检查",
        "condition": "周日 evening/night 或 超过7天未检查",
        "details": [
          "遍历 closet.json 和 aging_tracker.json",
          "计算每件衣服的 condition_score",
          "检查是否有 condition=damaged 的紧急情况",
          "检查是否有 favorite=worn/old 的关注情况",
          "更新 indices.json 的场合覆盖",
          "如果有问题，触发 disposal_process 或 update_suggestions"
        ]
      }
    ]
  },
  
