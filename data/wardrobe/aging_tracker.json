  "update_rules": {
    "description": "状态更新时机",
    "triggers": [
      {
        "trigger": "每次穿着结束",
        "action": "增加 wear_damage"
      },
      {
        "trigger": "每次洗涤",
        "action": "增加 wash_damage"
      },
      {
        "trigger": "发生意外",
        "action": "记录事故，增加 accident_damage"
      },
      {
        "trigger": "修补/护理",
        "action": "恢复部分 score"
      },
      {
        "trigger": "periodic_check",
        "frequency": "每周检查",
        "action": "重新计算所有衣服的 condition_score"
      }
    ],
    "sync_to_closet": {
      "description": "同步到 closet.json",
      "rule": "每次 condition_score 变化后，更新 closet.json 中对应衣服的 condition 字段"
    }
  },
  
