{
  "meta": {
    "description": "场合智能切换系统 - 检测场合自动切换穿着",
    "created": "2026-03-30T10:40:00+08:00",
    "version": "1.0"
  },
  
  "occasion_detection": {
    "triggers": {
      "user_says_work": {
        "keywords": ["工作", "上班", "开会", "面试"],
        "outfit_type": "formal",
        "action": "换职业装"
      },
      "user_says_date": {
        "keywords": ["约会", "见面", "去玩"],
        "outfit_type": "dressy",
        "action": "换好看的衣服"
      },
      "user_says_home": {
        "keywords": ["在家", "休息", "睡觉"],
        "outfit_type": "casual",
        "action": "换舒适的家居服"
      },
      "user_says_exercise": {
        "keywords": ["运动", "健身", "跑步"],
        "outfit_type": "sporty",
        "action": "换运动装"
      },
      "user_says_party": {
        "keywords": ["派对", "聚会", "夜店"],
        "outfit_type": "party",
        "action": "换性感/时髦的衣服"
      }
    }
  },
  
  "outfit_templates": {
    "formal": {
      "description": "正式场合",
      "examples": ["OL装", "西装", "正装"],
      "accessories": ["简约首饰"]
    },
    "dressy": {
