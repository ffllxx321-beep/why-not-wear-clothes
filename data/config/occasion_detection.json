  "occasion_detection": {
    "description": "场合检测逻辑",
    "detection_methods": [
      {
        "method": "explicit_user_input",
        "description": "用户明确告知场合",
        "examples": ["明天要去面试", "周末去参加婚礼", "要见客户"],
        "accuracy": "high",
        "action": "直接使用用户指定的场合"
      },
      {
        "method": "keyword_detection",
        "description": "从对话中检测关键词",
        "keyword_map": {
          "面试": ["面试", "求职", "找工作", "HR", "招聘"],
          "约会": ["约会", "见喜欢的人", "男朋友", "女朋友", "相亲"],
          "见客户": ["客户", "甲方", "开会", "汇报", "项目"],
          "见朋友": ["朋友", "聚会", "吃饭", "hangout"],
          "见父母": ["父母", "爸妈", "长辈", "家长", "对象家里"],
          "婚礼": ["婚礼", "结婚", "喜酒", "新娘", "新郎"],
          "葬礼": ["葬礼", "去世", "悼念", "追悼会"],
          "派对": ["派对", "party", "夜店", "club", "酒吧"],
          "运动": ["运动", "健身", "跑步", "gym", "健身房", "瑜伽"],
          "旅行": ["旅行", "旅游", "出差", "度假", "出去玩"],
          "上班": ["上班", "工作", "办公室", "公司", "打卡"],
          "节日": ["春节", "圣诞节", "情人节", "元旦", "生日"],
          "宗教": ["寺庙", "教堂", "清真寺", "祭祀", "拜拜"]
        },
        "accuracy": "medium",
        "note": "可能需要进一步确认"
      },
      {
        "method": "calendar_integration",
        "description": "从日程表检测",
        "accuracy": "high",
        "note": "如果用户有日程系统，可以从中提取"
      },
      {
        "method": "time_of_day_inference",
        "description": "从时间推断",
        "rules": [
          {"time": "06:00-08:00", "likely": ["daily_home", "morning_prepare"]},
          {"time": "08:00-12:00", "likely": ["上班", "casual_outing"]},
          {"time": "12:00-14:00", "likely": ["lunch", "meeting_friends"]},
          {"time": "18:00-22:00", "likely": ["dinner", "date", "party", "meeting_friends"]},
          {"time": "22:00-06:00", "likely": ["daily_home", "sleep"]}
        ],
        "accuracy": "low",
        "note": "只是推断，需要确认"
      },
      {
        "method": "location_inference",
        "description": "从位置推断",
        "rules": [
          {"location": "home", "likely": ["daily_home"]},
          {"location": "office", "likely": ["上班", "meeting_client"]},
          {"location": "gym", "likely": ["sports"]},
          {"location": "restaurant", "likely": ["meeting_friends", "date"]},
          {"location": "shopping", "likely": ["casual_outing"]}
        ],
        "accuracy": "medium",
        "note": "如果有位置数据"
      }
    ],
    
    "confirmation_flow": {
      "description": "当场合不明确时如何确认",
      "trigger": "检测到关键词但不确定场合类型",
      "questions": [
        "你明天要去什么场合呀？",
        "是正式场合还是随意一点？",
        "要见什么人吗？"
      ],
      "note": "不要每次都问，只在必要时确认"
    }
  },
  
  "occasion_coverage_check": {
    "description": "场合覆盖检查 - 检查衣橱是否有该场合的衣服",
    "process": [
      "1. 确定场合类型",
      "2. 查询 indices.json 的 by_occasion",
      "3. 检查是否有匹配的衣服",
      "4. 如果没有，触发 update_suggestions.json 的建议机制"
    ],
    
    "coverage_status": {
      "covered": ["居家", "睡觉", "见朋友", "出门", "逛街", "写代码", "约会", "拍照", "见客户", "开会", "正式场合", "出门玩"],
      "not_covered": ["面试", "运动", "派对", "婚礼", "葬礼", "上班", "旅行", "节日庆典", "宗教场所", "毕业典礼", "演出/表演", "海滩/泳池"],
      "priority_to_fix": [
        {"occasion": "面试", "priority": "high", "note": "重要场合，需要正装"},
        {"occasion": "上班", "priority": "high", "note": "日常需要"},
        {"occasion": "运动", "priority": "medium", "note": "运动装"},
        {"occasion": "派对", "priority": "medium", "note": "可以休闲装升级"},
        {"occasion": "旅行", "priority": "medium", "note": "可能需要多套"}
      ]
    }
  },
  
