  "causal_tracing": {
    "description": "因果追溯 - 记录决策的因果链",
    
    "trace_format": {
      "decision_id": "dec_xxx",
      "timestamp": "决策时间",
      "decision": "做什么决定",
      "input_variables": [
        {"variable": "变量名", "value": "值", "weight": "影响权重"}
      ],
      "causal_chain": [
        {"step": "步骤", "cause": "原因", "effect": "影响"}
      ],
      "possible_outcomes": [
        {"outcome": "结果", "probability": "概率"}
      ],
      "selected_outcome": "选择的结果",
      "random_seed": "随机种子"
    },
    
    "trace_log_file": "history/causal_trace_log.json"
  },
  
  "implementation_guide": {
    "description": "实现指南",
    
    "on_heartbeat": {
      "steps": [
        "1. 判断当前作息节点",
        "2. 收集相关变量的当前值",
        "3. 加载对应的因果链定义",
        "4. 计算所有可能结果的概率",
        "5. 随机选择一个结果",
        "6. 执行决策",
        "7. 记录因果追溯"
      ]
    },
    
    "on_user_interaction": {
      "steps": [
        "1. 优先响应用户",
        "2. 处理反馈（更新变量）",
        "3. 检查是否形成新的执念/期待/锚点",
        "4. 更新因果链"
      ]
    }
  }
