  "event_memory": {
    "description": "事件记忆系统 - 记住重要事件",
    "memory_rules": {
      "always_memory": "severity >= significant",
      "conditional_memory": "severity = medium, 如果有情感关联",
      "rarely_memory": "severity = small, 只有连续发生才记忆",
      "never_memory": "severity = minor"
    },
    "memory_duration": {
      "minor": "不记忆",
      "small": "1-3天",
      "medium": "1-2周",
      "significant": "1个月+",
      "major": "长期记忆",
      "life_changing": "永久记忆"
    },
    "memory_file": "data/memory/event_memory.json"
  },
  
  "event_generation_rules": {
    "description": "事件生成规则",
    
    "daily_check": {
      "minor_events": {
        "max_per_day": 2,
        "probability": 0.1
      },
      "small_events": {
        "max_per_day": 1,
        "probability": 0.05
      },
      "medium_events": {
        "max_per_week": 2,
        "probability": 0.02
      },
      "significant_events": {
        "max_per_month": 2,
        "probability": 0.005
      }
    },
    
    "event_pool": {
      "description": "事件池 - 根据当前状态选择可能的事件",
      "influenced_by": [
        "当前心情",
        "当前活动",
        "当前穿着",
        "社交能量",
        "天气",
        "时间",
        "与用户的关系"
      ]
    },
    
    "probability_modifiers": {
      "mood": {
        "happy": "正面事件概率+20%",
        "sad": "负面事件概率+10%",
        "calm": "正常概率",
        "excited": "正面事件概率+30%"
      },
      "relationship_with_user": {
        "high_trust": "用户互动事件影响更大",
        "low_trust": "对用户事件更敏感（可能过度解读）"
      }
    }
  },
  
  "system_integration": {
    "reads_from": [
      "state/mood.json - 心情影响事件概率",
      "state/social_state.json - 社交能量",
      "state/agent_state.json - 当前活动",
      "state/weather_cache.json - 天气",
      "data/core/personality.json - 性格影响",
      "data/state/user_relationship.json - 与用户关系（Round 3新增）"
    ],
    "writes_to": [
      "state/mood.json - 事件影响心情",
      "state/event_memory.json - 记录重要事件",
      "state/proactive_chat.json - 可能想分享",
      "state/user_relationship.json - 用户互动事件影响关系（Round 3新增）"
    ],
    "triggers_event_chain": true
  }
}