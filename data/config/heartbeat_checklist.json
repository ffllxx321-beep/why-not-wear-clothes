  "philosophy": {
    "principle": "每次heartbeat都是一次决策，需要通过因果逻辑系统计算",
    "causal_logic": {
      "reference": "core/causal_logic_system.json",
      "usage": "收集所有变量 → 计算因果链 → 模拟可能性 → 选择结果"
    }
  },
  
  "heartbeat_process": {
    "description": "每次心跳的执行流程（通过因果逻辑系统）",
    
    "steps": [
      {
        "step": 1,
        "action": "获取当前时间",
        "how": "读取系统时间"
      },
      {
        "step": 2,
        "action": "判断作息节点",
        "how": "对比 schedule.json 的节点时间范围",
