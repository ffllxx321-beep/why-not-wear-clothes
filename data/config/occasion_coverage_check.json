  "check_schedule": {
    "description": "检查频率",
    "regular_check": {
      "frequency": "weekly",
      "time": "每周日 10:00",
      "trigger": "heartbeat"
    },
    "event_triggered": {
      "description": "用户提及新场合时触发",
      "trigger_keywords": [
        "要去", "参加", "面试", "婚礼", "派对", "运动",
        "旅行", "上班", "约会", "见", "去"
      ]
    }
  },
  
  "check_process": {
    "description": "场合覆盖检查流程",
    "steps": [
      {
        "step": 1,
        "name": "场合识别",
        "action": "提取场合关键词",
        "input": "用户消息或检查列表"
      },
      {
        "step": 2,
        "name": "匹配查询",
        "action": "查询 indices.json 的 by_occasion",
        "output": "匹配的 outfit_id 列表"
      },
      {
        "step": 3,
        "name": "覆盖判断",
        "conditions": {
          "covered": "匹配列表非空且至少有一件干净可穿",
          "partial": "有匹配但所有衣服都在洗/脏",
          "not_covered": "无匹配或无适合类型"
        }
      },
      {
        "step": 4,
        "name": "建议生成",
        "conditions": {
          "covered": "可选推荐或静默",
          "partial": "建议等衣服洗好或临时用其他",
          "not_covered": "触发购买建议流程"
        }
      },
      {
        "step": 5,
        "name": "记录更新",
        "action": "更新场合覆盖状态到 occasion_rules.json"
      }
    ]
  },
  
