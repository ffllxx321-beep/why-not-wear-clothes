  "quick_start_flow": {
    "description": "新用户3步完成配置",
    
    "step_1_choose_preset": {
      "trigger": "首次使用穿衣功能",
      "message": "我还没有衣服穿呢！要帮我配置衣橱吗？",
      "options": [
        {
          "preset": "minimal",
          "name": "极简衣橱",
          "description": "3件基础款：睡衣、休闲装、正装",
          "recommend_for": "新用户、不确定的用户"
        },
        {
          "preset": "comfy",
          "name": "舒适优先",
          "description": "4件舒适款：睡衣、家居服、休闲装、外套",
          "recommend_for": "注重舒适的用户"
        },
        {
          "preset": "varied",
          "name": "多样化衣橱",
          "description": "6件多场合：睡衣、家居服、休闲装、连衣裙、正装、外套",
          "recommend_for": "想要更多选择的用户"
        },
        {
          "preset": "custom",
          "name": "自定义",
          "description": "一件一件添加",
          "recommend_for": "有特定需求的用户"
        }
      ]
    },
    
    "step_2_confirm_preferences": {
      "trigger": "预设选择完成后",
      "message": "好嘞！你希望我偏好什么风格？",
      "auto_detect": {
        "source": "USER.md/SOUL.md",
        "fields": ["favorite_colors", "favorite_styles", "comfort_priority"]
      },
      "fallback": "使用默认偏好（淡蓝色、米白色、舒适优先）"
    },
    
    "step_3_complete": {
      "trigger": "偏好确认后",
      "message": "搞定！我现在有衣服穿了～",
      "actions": [
        "更新setup_status.json为completed",
        "生成primary.jpg基准照片（可选）"
      ]
    }
  },
  
