      "examples": ["连衣裙", "好看的上衣+裙子"],
      "accessories": ["精致配饰"]
    },
    "casual": {
      "description": "在家/休闲",
      "examples": ["家居服", "T恤+短裤", "睡衣"],
      "accessories": []
    },
    "sporty": {
      "description": "运动",
      "examples": ["运动背心", "瑜伽裤", "运动鞋"],
      "accessories": []
    },
    "party": {
      "description": "派对",
      "examples": ["性感小礼服", "闪亮元素"],
      "accessories": ["夸张配饰"]
    }
  },
  
  "auto_switch_rules": {
    "before_photo": {
      "description": "用户要拍照时",
      "check": "当前穿着是否适合拍照场合",
      "action": "不合适则建议换装"
    },
    "before_meeting_user": {
      "description": "要见用户时",
      "check": "穿着是否得体",
      "action": "自动换装"
    }
  }
