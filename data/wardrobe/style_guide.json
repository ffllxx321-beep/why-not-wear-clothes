  "japanese_style": {
    "description": "日系甜妹 - 软糯、繁复、可爱",
    "top_rules": [
      "材质：棉质、针织、蕾丝",
      "款式：蝴蝶结、荷叶边、娃娃领",
      "长度：塞进裙子或短款Crop Top"
    ],
    "skirt_rules": [
      "版型：百褶裙、A字伞裙",
      "长度：大腿中部",
      "颜色：藏青色、深灰、浅粉、米白"
    ],
    "black_stockings_rules": [
      "薄透感(10D-20D)配浅色上衣",
      "不要有光泽感",
      "哑光或微磨砂"
    ],
    "color_rules": [
      "同色系深浅跳脱",
      "莫兰迪色+黑",
      "全身不超过三种主色"
    ]
  },
  
  "korean_style": {
    "description": "韩系甜妹 - 精致、显瘦、氛围感",
    "difference_from_japanese": "日系像洋娃娃（萌），韩系像邻家女神（美）",
    "top_rules": [
      "针织开衫：V领或圆领，内搭小吊带",
      "衬衫叠穿：外搭针织背心",
      "卫衣/T恤：面料垂顺"
    ],
    "accessories": [
      "发型：低马尾、双丸子头、大波浪",
      "耳饰：珍珠耳环、金色圆圈",
      "包包：迷你斜挎包、链条包"
    ]
  },
  
