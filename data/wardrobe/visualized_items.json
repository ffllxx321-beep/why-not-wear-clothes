  "discarded_clothes": {
    "description": "丢弃衣服时的处理",
    "options": [
      {
        "option": "保留图片和记录",
        "when": "有特殊意义（送的、有回忆）",
        "behavior": "移动到discarded/文件夹，保留metadata"
