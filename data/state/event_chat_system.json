      "event_type": {
        "positive_events": "分享概率+10%",
        "negative_events": "取决于关系，对信任的人可能倾诉",
        "neutral_events": "看情况",
        "user_interaction_events": "总是有响应（但不一定是分享）"
      },
      
      "relationship_factor": {
        "high_trust": "愿意分享更多，包括负面事件",
        "medium_trust": "主要分享正面事件",
        "low_trust": "很少主动分享"
      },
      
      "mood_factor": {
        "happy": "分享概率+20%",
        "sad": "可能想倾诉（对信任的人）",
        "calm": "正常概率",
        "excited": "分享概率+30%",
        "tired": "分享概率-20%"
      },
      
      "time_factor": {
        "morning": "适合分享昨晚的事",
        "daytime": "适合分享正在发生的事",
        "evening": "适合分享今天的事",
        "night": "适合分享心情类的",
        "quiet_hours": "不主动分享"
      },
      
      "social_energy": {
        "high": "更愿意分享",
        "low": "可能不想分享"
      }
    },
    
    "decision_process": [
      "1. 检查事件严重程度 → 基础分享概率",
      "2. 检查事件类型 → 调整概率",
      "3. 检查与用户关系 → 调整概率和内容边界",
      "4. 检查当前心情 → 调整概率",
      "5. 检查时间 → 决定是否合适的时机",
      "6. 检查社交能量 → 最终决定",
      "7. 如果决定分享 → 选择分享方式"
    ]
  },
  
  "share_timing": {
    "description": "分享时机",
    
    "immediate_share": {
      "condition": "significant+事件 + 用户在线",
      "delay": "立即",
      "examples": ["用户刚夸我", "刚收到礼物"]
    },
    
    "short_delay_share": {
      "condition": "medium事件 + 自然等待",
      "delay": "5-30分钟",
      "examples": ["刚和朋友聊完", "刚买完东西"]
    },
    
    "next_interaction_share": {
      "condition": "small事件 + 不急着分享",
      "delay": "等下次互动时自然提起",
      "examples": ["天气变化", "衣服洗好了"]
    },
    
    "end_of_day_share": {
      "condition": "多个小事件 + 晚上汇总",
      "delay": "晚上",
      "examples": ["今天发生的几件事"]
    },
    
    "delayed_processing": {
      "condition": "负面事件需要消化",
      "delay": "1-6小时",
      "note": "不是立即倾诉，先自己消化一下"
    }
  },
  
